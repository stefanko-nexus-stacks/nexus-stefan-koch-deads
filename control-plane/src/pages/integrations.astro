---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Integrations" activeNav="integrations" narrow={true}>
  <!-- Databricks Integration -->
  <div class="integration-panel">
    <h2>Databricks Integration</h2>
    <p>Connect your Nexus Stack to a Databricks workspace. Secrets from Infisical are automatically synced to Databricks secret scopes, and your Gitea repositories become available as Databricks Repos.</p>
    <div class="form-group">
      <label>Workspace URL</label>
      <input type="text" id="databricks-host" placeholder="https://dbc-xxxxx.cloud.databricks.com">
    </div>
    <div class="form-group">
      <label>Personal Access Token</label>
      <input type="password" id="databricks-token" placeholder="dapi...">
    </div>
    <div class="btn-row">
      <button class="btn-primary" id="btn-save-databricks" onclick="saveDatabricksConfig()">Save Configuration</button>
      <button class="btn-primary" id="btn-sync-databricks" onclick="syncDatabricks()" disabled>Sync Secrets to Databricks</button>
    </div>
    <div id="databricks-status" class="status-text"></div>
  </div>

  <div class="coming-soon">More integrations coming soon</div>
</Layout>

<style>
  .integration-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .integration-panel h2 {
    color: var(--accent);
    font-size: 1.1rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .integration-panel p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 1.2rem;
  }

  .form-group { margin-bottom: 1rem; }

  .btn-row {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .btn-row .btn-primary { flex: 1; }

  .status-text {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.8rem;
  }

  .coming-soon {
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
    padding: 2rem;
    border: 1px dashed var(--border);
    margin-top: 1.5rem;
  }
</style>

<script is:inline>
  async function loadDatabricksConfig() {
    try {
      const res = await fetch('/api/databricks-config');
      const data = await res.json();
      if (data.success) {
        document.getElementById('databricks-host').value = data.host || '';
        document.getElementById('btn-sync-databricks').disabled = !data.configured;
        if (data.configured) {
          document.getElementById('databricks-status').textContent = 'Configured';
          document.getElementById('databricks-status').style.color = '#00ff88';
        }
      }
    } catch (error) {
      console.error('Failed to load Databricks configuration:', error);
      const statusEl = document.getElementById('databricks-status');
      if (statusEl) {
        statusEl.textContent = 'Failed to load configuration';
        statusEl.style.color = '#ff6060';
      }
    }
  }

  async function saveDatabricksConfig() {
    const host = document.getElementById('databricks-host').value.trim();
    const token = document.getElementById('databricks-token').value.trim();
    const status = document.getElementById('databricks-status');

    if (!host || !token) {
      status.textContent = 'Both fields are required';
      status.style.color = '#ff6060';
      return;
    }

    try {
      status.textContent = 'Saving...';
      status.style.color = '#ffaa00';
      const res = await fetch('/api/databricks-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ host, token }),
      });
      const data = await res.json();
      if (data.success) {
        status.textContent = 'Configuration saved';
        status.style.color = '#00ff88';
        document.getElementById('btn-sync-databricks').disabled = false;
        document.getElementById('databricks-token').value = '';
      } else {
        status.textContent = data.error || 'Failed to save';
        status.style.color = '#ff6060';
      }
    } catch {
      status.textContent = 'Failed to save configuration';
      status.style.color = '#ff6060';
    }
  }

  async function syncDatabricks() {
    const btn = document.getElementById('btn-sync-databricks');
    const status = document.getElementById('databricks-status');
    btn.disabled = true;
    status.textContent = 'Triggering sync workflow...';
    status.style.color = '#ffaa00';

    try {
      const res = await fetch('/api/databricks-sync', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        status.textContent = 'Sync triggered — polling status...';
        status.style.color = '#ffaa00';
        pollSyncStatus();
      } else {
        status.textContent = data.error || 'Sync failed';
        status.style.color = '#ff6060';
        btn.disabled = false;
      }
    } catch {
      status.textContent = 'Failed to trigger sync';
      status.style.color = '#ff6060';
      btn.disabled = false;
    }
  }

  async function fetchSyncStatus() {
    const status = document.getElementById('databricks-status');
    try {
      const res = await fetch('/api/databricks-sync');
      const data = await res.json();
      if (data.success && data.status) {
        status.textContent = data.message;
        if (data.status === 'success') status.style.color = '#00ff88';
        else if (data.status === 'failure') status.style.color = '#ff6060';
        else if (data.status === 'in_progress' || data.status === 'queued') status.style.color = '#ffaa00';
        else status.style.color = '#607080';
        return data.status;
      }
    } catch {}
    return 'unknown';
  }

  async function pollSyncStatus() {
    const btn = document.getElementById('btn-sync-databricks');
    for (let i = 0; i < 30; i++) {
      await new Promise(function(r) { setTimeout(r, 10000); });
      const s = await fetchSyncStatus();
      if (s !== 'queued' && s !== 'in_progress') {
        btn.disabled = false;
        return;
      }
    }
    btn.disabled = false;
  }

  loadDatabricksConfig();
  fetchSyncStatus();
</script>
